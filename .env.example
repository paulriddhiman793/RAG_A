# ── Unstructured.io API ──────────────────────────────────────────────
UNSTRUCTURED_API_KEY=your_unstructured_api_key_here
UNSTRUCTURED_API_URL=https://api.unstructured.io/general/v0/general

# ── Groq Cloud API ───────────────────────────────────────────────────
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── LLM Model ────────────────────────────────────────────────────────
# Available Groq models (as of 2025):
#   llama-3.3-70b-versatile      ← best quality, recommended
#   llama-3.1-8b-instant         ← fastest, lowest cost
#   mixtral-8x7b-32768           ← good for long contexts
#   gemma2-9b-it                 ← lightweight
#   llama3-groq-70b-8192-tool-use-preview  ← best for tool/function use
LLM_MODEL=llama-3.3-70b-versatile

# ── Vector Store ─────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=rag_collection

# ── Embedding Model ───────────────────────────────────────────────────
# Options: intfloat/multilingual-e5-large (default, handles 100+ languages)
#          pritamdeka/BioBERT-mnli-snli-scinli-scitail-mednli-stsb (biomedical)
#          nlpaueb/legal-bert-base-uncased (legal)
DEFAULT_EMBEDDING_MODEL=intfloat/multilingual-e5-large

# ── Retrieval ─────────────────────────────────────────────────────────
VECTOR_SEARCH_TOP_K=30
BM25_TOP_K=30
RERANK_TOP_K=5
RELEVANCE_THRESHOLD=0.35

# ── Chunking ─────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
PARENT_CHUNK_SIZE=1536

# ── Context ───────────────────────────────────────────────────────────
MAX_CONTEXT_TOKENS=6000

# ── Document Recency (days before full decay penalty) ─────────────────
RECENCY_DECAY_DAYS=365

# Agentic mode
AUTO_ROUTE_QUERIES=true
AGENT_MAX_STEPS=5
AGENT_MEMORY_DIR=./agent_sessions

# Tool prompt templates (configurable from .env)
TOOL_PROMPT_SUMMARIZE_DOCUMENT=Summary of pdf
TOOL_PROMPT_EXPLAIN_FIGURE=Kindly explain Figure {figure_number} properly
TOOL_PROMPT_COMPARE_FIGURES=What is the difference between Figure {left_figure} and Figure {right_figure}?
TOOL_PROMPT_LOOKUP_TABLE=Explain Table {table_number} briefly and state its contents.
TOOL_PROMPT_COMPARE_TABLES=What is the difference between Table {left_table} and Table {right_table}?
TOOL_PROMPT_LOOKUP_FORMULA=mention the {formula_hint} equation
TOOL_PROMPT_LOOKUP_FORMULA_ALL=Properly mention all the equations in the pdf
TOOL_PROMPT_LOOKUP_METRIC=What is the {metric_name} score of {model_name} model
